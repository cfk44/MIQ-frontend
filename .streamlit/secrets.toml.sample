# Streamlit secrets template — rename to secrets.toml for local development
# secrets.toml is gitignored and never committed.
# For the deployed app, paste these same keys into:
#   Streamlit Cloud → App settings → Secrets

# ─── Backend URLs ─────────────────────────────────────
# Resolved by app.py based on Makefile target:
#   make streamlit_local  →  uses local_api_uri  (uvicorn on :8000)
#   make streamlit_cloud  →  uses cloud_api_uri  (deployed Cloud Run)
#   Streamlit Cloud       →  uses cloud_api_uri  (default fallback)

local_api_uri = "http://127.0.0.1:8000"
cloud_api_uri = "YOUR_CLOUD_RUN_URL"
EOF
