# Environment variables for local development
# This file is gitignored — never commit secrets to GitHub
#
# Usage: load with python-dotenv → from dotenv import load_dotenv; load_dotenv()
#
# Examples (uncomment and fill in when needed):
#
# Third-party APIs
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# STRAVA_CLIENT_SECRET=...
#
# Database
# DATABASE_URL=postgres://user:pass@host:5432/dbname
#
# Cloud credentials
# GOOGLE_APPLICATION_CREDENTIALS=./credentials/gcp-key.json
#
# Feature flags
# DEBUG=true
# LOG_LEVEL=info
#
# Note: Backend URL is now managed in .streamlit/secrets.toml
